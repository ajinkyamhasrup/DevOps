pipeline {
    agent { label 'linux' }
    stages {


        stage('Tomcat_start_stop') {
            dir('ansible') {
             if (params.Action == "start") {
sh "export ANSIBLE_FORCE_COLOR=true; ansible-playbook tomcat.yml -e act=${params.Action}"
            }
             else
             {
sh "export ANSIBLE_FORCE_COLOR=true; ansible-playbook tomcat.yml -e act=${params.Action}"
             }

          } //stage
        } //dir
    }
}


