pipeline {
    agent {
        label 'linux'
    }

    parameters {
        choice(
            name: 'Action',
            choices: ['install', 'deploy', 'start', 'stop'],
            description: 'Select Tomcat action'
        )
    }

    stages {

        stage('Tomcat Management') {

            steps {
                dir('ansible') {

                    script {

                        if (params.Action == 'install') {

                            sh '''
                            export ANSIBLE_FORCE_COLOR=true
                            ansible-playbook install_tomcat.yml
                            '''

                        } else if (params.Action == 'deploy') {

                            sh '''
                            export ANSIBLE_FORCE_COLOR=true
                            ansible-playbook deploy_app.yml
                            '''

                        } else if (params.Action == 'start') {

                            sh '''
                            export ANSIBLE_FORCE_COLOR=true
                            ansible-playbook tomcat.yml -e act=start
                            '''

                        } else if (params.Action == 'stop') {

                            sh '''
                            export ANSIBLE_FORCE_COLOR=true
                            ansible-playbook tomcat.yml -e act=stop
                            '''

                        }

                    }
                }
            }
        }
    }
}